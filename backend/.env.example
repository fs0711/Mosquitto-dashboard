# Mosquitto broker connection
MQTT_HOST=localhost
MQTT_PORT=1884
MQTT_USERNAME=
MQTT_PASSWORD=

# Mosquitto file paths (standard Linux install)
MOSQUITTO_CONF=/etc/mosquitto/mosquitto.conf
MOSQUITTO_PASSWD=/etc/mosquitto/passwd
MOSQUITTO_ACL=/etc/mosquitto/acl
MOSQUITTO_CERTS_DIR=/etc/mosquitto/certs
MOSQUITTO_LOG=/var/log/mosquitto/mosquitto.log

# Optional: PID file location (for SIGHUP reload)
MOSQUITTO_PID=/run/mosquitto/mosquitto.pid

# Max config backups to keep
CONFIG_MAX_BACKUPS=5

# Redis (for MQTT topic history)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
TOPIC_HISTORY_LENGTH=30

# Backend server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5013
